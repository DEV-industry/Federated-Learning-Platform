# Example environment file for FL node client on physical device
# Source this file before starting node client: source node-config.env && python main.py

# Device Runtime Configuration
MODEL_CACHE_DIR=/mnt/persistent/fl-cache/models
CHECKPOINT_DIR=/mnt/persistent/fl-cache/checkpoints
DEVICE_RUNTIME_CONFIG_PATH=/etc/fl-platform/node-config.json
WATCHDOG_ENABLED=true
WATCHDOG_CHECK_INTERVAL=30

# Network & Aggregator
NODE_ENDPOINT_MODE=external
AGGREGATOR_EXTERNAL_BASE_URL=https://aggregator-api.example.com:8443
AGGREGATOR_EXTERNAL_GRPC_URL=aggregator-api.example.com:9443
TLS_VERIFY=true
TLS_CA_CERT_PATH=/etc/fl-platform/ca.crt

# Device Identity (Physical Device Attributes)
NODE_ID=physical-node-1
CLIENT_VERSION=node-client-1.0.0
DEVICE_MODEL=Dell-XPS-15
DEVICE_OS=Ubuntu-22.04-x86_64
DEVICE_CPU=Intel-Core-i7-12700K
DEVICE_GPU=NVIDIA-RTX-3060
DEVICE_REGION=eu-west-1

# Enrollment & Security (if first-time provisioning)
NODE_PRIVATE_KEY_PATH=/var/lib/fl-node/.node_identity_ed25519.pem
NODE_ENROLLMENT_TOKEN=token_abc123def456  # TTL: single use, expires after first auth

# Training Hyperparameters (Defaults, can be overridden by aggregator)
DP_ENABLED=true
DP_NOISE_MULTIPLIER=0.01
FEDPROX_MU=0.01
DATA_PARTITION_FRACTION=0.5
HEARTBEAT_INTERVAL=20

# Homomorphic Encryption (if shared across fleet)
HE_ENABLED=true
HE_SHARED_CONTEXT_FILE=/var/lib/fl-node/shared_he_context.b64
# OR for inline context:
# HE_SHARED_CONTEXT_B64=<base64-encoded-context>

# Logging & Metrics
ACTIVITY_REPORT_BATCH_INTERVAL=100
