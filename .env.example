# =================================================================
# Federated Learning Platform — Environment Variables Template
# =================================================================

# PostgreSQL
POSTGRES_USER=<your-postgres-user>
POSTGRES_PASSWORD=<your-strong-postgres-password>
POSTGRES_DB=fldb

# JWT / Node Authentication
# JWT_SECRET MUST be at least 32 bytes (256 bits) for HS256 algorithm security.
# Generate with: openssl rand -base64 32
# The application will reject any key shorter than 32 bytes.
JWT_SECRET=<your-jwt-signing-secret-minimum-32-bytes>
# Node Authentication: Each node generates its own Ed25519 key pair locally on startup.
# Per-node public keys are registered with the aggregator. No shared secret needed.

# FedProx Hyperparameter
FEDPROX_MU=0.01

# Transport Security (Node Client <-> Aggregator)
AGGREGATOR_BASE_URL=https://aggregator:8443
AGGREGATOR_GRPC_URL=aggregator:9443
TLS_VERIFY=true
# Path inside containers. Mount ./certs into /certs in docker-compose.
TLS_CA_CERT_PATH=/certs/ca.crt
# Optional for gRPC hostname override when cert SAN/CN differs from DNS target.
GRPC_SSL_TARGET_NAME_OVERRIDE=

# Aggregator TLS certificates (mounted into container)
SERVER_SSL_CERTIFICATE=/certs/aggregator-server.crt
SERVER_SSL_CERTIFICATE_PRIVATE_KEY=/certs/aggregator-server.key
GRPC_SERVER_SECURITY_CERTIFICATE_CHAIN=/certs/aggregator-server.crt
GRPC_SERVER_SECURITY_PRIVATE_KEY=/certs/aggregator-server.key

# MinIO Object Storage
MINIO_ROOT_USER=<your-minio-user>
MINIO_ROOT_PASSWORD=<your-strong-minio-password>
MINIO_BUCKET=fl-models

# RabbitMQ
RABBITMQ_DEFAULT_USER=<your-rabbitmq-user>
RABBITMQ_DEFAULT_PASS=<your-strong-rabbitmq-password>

# Grafana
GRAFANA_PASSWORD=<your-strong-grafana-password>
