# =================================================================
# Federated Learning Platform — Environment Variables Template
# =================================================================

# PostgreSQL
POSTGRES_USER=<your-postgres-user>
POSTGRES_PASSWORD=<your-strong-postgres-password>
POSTGRES_DB=fldb

# JWT / Node Authentication
JWT_SECRET=<your-jwt-signing-secret-min-32-chars>
# Node Authentication: Each node generates its own Ed25519 key pair locally on startup.
# Per-node public keys are registered with the aggregator. No shared secret needed.

# FedProx Hyperparameter
FEDPROX_MU=0.01

# MinIO Object Storage
MINIO_ROOT_USER=<your-minio-user>
MINIO_ROOT_PASSWORD=<your-strong-minio-password>
MINIO_BUCKET=fl-models

# RabbitMQ
RABBITMQ_DEFAULT_USER=<your-rabbitmq-user>
RABBITMQ_DEFAULT_PASS=<your-strong-rabbitmq-password>

# Grafana
GRAFANA_PASSWORD=<your-strong-grafana-password>
